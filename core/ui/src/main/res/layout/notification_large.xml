<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <!-- Header Section (Matches Small Notification) -->
    <ImageView
        android:id="@+id/notification_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentStart="true"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Icon"
        android:scaleType="centerCrop"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/header_text_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notification_icon"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_title"
            style="@style/TextAppearance.Compat.Notification.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notification Title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/notification_title_color"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notification_desc"
            style="@style/TextAppearance.Compat.Notification.Info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detailed description text goes here..."
            android:textSize="14sp"
            android:textColor="@color/notification_body_color"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Expanded Section (The Big Image) -->
    <ImageView
        android:id="@+id/notification_big_image"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/header_text_container"
        android:layout_marginTop="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/bismillah"
        android:visibility="visible"
        android:contentDescription="Big Notification Image" />

</RelativeLayout>